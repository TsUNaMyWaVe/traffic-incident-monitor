{
  "name": "traffic-incident-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch --clear-screen=false src/server/index.ts",
    "dev:client": "cd client && vite --host",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\" \"client/src/**/*.{js,ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint --fix \"src/**/*.{js,ts,tsx}\" \"client/src/**/*.{js,ts,tsx}\"",
    "migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "rollback": "knex --knexfile knexfile.cjs migrate:rollback"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "knex": "^2.5.1",
    "mysql2": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
